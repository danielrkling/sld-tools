{
  "scopeName": "text.sld",
  "injectionSelector": "L:source.js, L:source.ts T:template-string.sld",
  "patterns": [
    { "include": "#empty-closing-tag" },
    { "include": "#dynamic-tag" },
    { "include": "#tag" },
    { "include": "#comment" }
  ],
  "repository": {
    "empty-closing-tag": {
      "match": "(<\\s*)(//\\s*>)",
      "captures": {
        "1": { "name": "punctuation.definition.tag.sld" },
        "2": { "name": "punctuation.definition.tag.sld" }
      }
    },
    "dynamic-tag": {
      "begin": "(<\\s*/?)\\s*(\\$\\{)([^}]*)(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.sld" },
        "2": { "name": "punctuation.definition.template-expression.begin.ts" },
        "3": { "name": "entity.name.class.sld" },
        "4": { "name": "punctuation.definition.template-expression.end.ts" }
      },
      "end": "(\\s*/?\\s*>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.sld" }
      },
      "patterns": [{ "include": "#tag-stuff" }]
    },
    "tag": {
      "begin": "(<\\s*/?)\\s*(?=[a-zA-Z])",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.sld" }
      },
      "end": "\\s*/?\\s*>",
      "endCaptures": { "0": { "name": "punctuation.definition.tag.sld" } },
      "patterns": [{ "include": "#tag-stuff" }]
    },
    "tag-stuff": {
      "patterns": [
        { "include": "#inside-string" },
        { "include": "#string-substitution" },
        {
          "match": "(?<=<\\s*/?\\s*)[A-Z][\\w\\-\\.]*",
          "name": "entity.name.class.sld"
        },
        {
          "match": "(?<=<\\s*/?\\s*)[a-z][\\w\\-\\.]*",
          "name": "entity.name.tag.sld"
        },
        { "name": "keyword.operator.assignment.sld", "match": "\\s*=\\s*" },
        { "name": "variable.parameter.sld", "match": "[a-zA-Z_][\\w\\-\\.:]*" },
        { "name": "variable.parameter.sld.spread", "match": "\\.\\.\\." }
      ]
    },
    "inside-string": {
      "patterns": [
        {
          "name": "string.quoted.sld",
          "begin": "(?<==\\s*)(\"|')",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.string.begin.sld" }
          },
          "end": "(?<!\\\\)\\1",
          "endCaptures": {
            "1": { "name": "punctuation.definition.string.end.sld" }
          },
          "patterns": [{ "include": "#string-substitution" }]
        }
      ]
    },
    "string-substitution": {
      "begin": "(\\$\\{)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.template-expression.begin.ts" }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": { "name": "punctuation.definition.template-expression.end.ts" }
      },
      "name": "meta.template.expression.ts",
      "contentName": "meta.embedded.ts",
      "patterns": [{ "include": "source.ts" }]
    },
    "comment": {
      "patterns": [
        {
          "name": "comment.block.sld",
          "begin": "<!--",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.sld" }
          },
          "end": "-->",
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.sld" }
          },
          "contentName": "comment.block.sld"
        }
      ]
    }
  }
}
