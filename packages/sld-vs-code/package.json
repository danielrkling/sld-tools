{
  "name": "sld-vs-code",
  "displayName": "JSX Tagged Templates",
  "description": "Syntax highlighting and language support for JSX tagged template literals.",
  "publisher": "danielrkling",
  "repository": {
    "url": "https://github.com/danielrkling/sld-tools"
  },
  "version": "0.0.1",
  "engines": {
    "vscode": ">=1.70.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "jsx",
    "tagged templates"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/web/extension.js",
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "contributes": {
    "configuration": {
      "title": "JSX Tagged Templates",
      "properties": {
        "jsx-tagged.preferredTag": {
          "type": "string",
          "default": "jsx",
          "enum": ["jsx", "sld"],
          "description": "Preferred tag name for JSX templates (jsx or sld)"
        }
      }
    },
    "languages": [
      {
        "id": "jsx-tagged",
        "extensions": [
          ".jsxt"
        ],
        "aliases": [
          "JSX Tagged",
          "jsxt"
        ]
      }
    ],
    "grammars": [
      {
        "injectTo": [
          "source.js",
          "source.js.jsx",
          "source.jsx",
          "source.ts",
          "source.tsx",
          "text.html"
        ],
        "scopeName": "text.lit-jsx",
        "path": "./syntaxes/lit-jsx.json",
        "embeddedLanguages": {
          "meta.embedded.block.jsx": "jsx-tagged"
        }
      },
      {
        "injectTo": [
          "source.js",
          "source.js.jsx",
          "source.jsx",
          "source.ts",
          "source.tsx",
          "text.html"
        ],
        "scopeName": "text.lit-jsx.string.injection",
        "path": "./syntaxes/lit-jsx-string-injection.json",
        "embeddedLanguages": {
          "meta.template.expression.ts": "typescript"
        }
      },
      {
        "language": "jsx-tagged",
        "scopeName": "text.jsx",
        "path": "./syntaxes/jsx.json"
      }
    ],
    "formatters": [
      {
        "id": "jsx Formatter",
        "languages": [
          "javascript",
          "typescript"
        ]
      }
    ],
    "typescriptServerPlugins": [
      {
        "name": "ts-plugin-jsx"
      }
    ],
    "commands": [
      {
        "command": "jsx-tagged.convertToJsx",
        "title": "JSX Tagged: Convert to jsx tag"
      },
      {
        "command": "jsx-tagged.convertToSld",
        "title": "JSX Tagged: Convert to sld tag"
      },
      {
        "command": "jsx-tagged.toggle",
        "title": "JSX Tagged: Toggle (Smart Convert)"
      }
    ],
    "keybindings": [
      {
        "command": "jsx-tagged.toggle",
        "key": "ctrl+shift+j",
        "mac": "cmd+shift+j",
        "when": "editorTextFocus && (language == 'typescript' || language == 'typescriptreact' || language == 'javascript' || language == 'javascriptreact')"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.70.0",
    "@vscode/test-web": "^0.0.73",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.9",
    "sld-ts-plugin": "file:../sld-ts-plugin",
    "sld-parse": "file:../sld-parse",
    "transform-jsx": "file:../transform-jsx",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {},
  "scripts": {
    "build:web": "esbuild ./src/extension.ts --bundle --format=cjs --outfile=./dist/web/extension.js --external:vscode --minify",
    "build": "esbuild ./src/extension.ts --bundle --format=cjs --outfile=./dist/extension.js --external:vscode --external:typescript --bundle --platform=node",
    "watch": "esbuild ./src/extension.ts --bundle --format=cjs --outfile=./dist/extension.js --external:vscode --watch",
    "prepublish": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}
