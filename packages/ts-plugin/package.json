{
  "name": "ts-plugin-tagged-jsx",
  "version": "1.0.0",
  "description": "TypeScript language service plugin for tagged JSX templates",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.cjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs --minify",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "typescript",
    "jsx",
    "language-service",
    "plugin",
    "tagged-template"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "tsdown": "^0.20.0-beta.3",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "dependencies": {
    "parse-jsx": "file:../parse",
    "solid-js": "^1.9.12",
    "transform": "file:../transform"
  },
  "directories": {
    "test": "tests"
  }
}
