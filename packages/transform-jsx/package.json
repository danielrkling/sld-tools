{
  "name": "transform-jsx",
  "version": "1.0.0",
  "description": "Transform between tagged template literals and JSX syntax",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.cjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs --minify",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "jsx",
    "transform",
    "template-literal",
    "tagged-template"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/diff": "^8.0.0",
    "@types/node": "^20.10.6",
    "solid-js": "^1.9.12",
    "tsdown": "^0.20.0-beta.3",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "dependencies": {
    "@babel/parser": "^8.0.0-rc.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^8.0.0-rc.2",
    "diff": "^7.0.0",
    "parse-jsx": "file:../parse-jsx",
    "recast": "^0.23.9",
    "typescript": "^5.3.3"
  }
}
