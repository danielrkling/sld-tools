{
  "name": "tagged-jsx-vscode",
  "displayName": "Tagged JSX Tools",
  "description": "Syntax highlighting and language support for JSX tagged template literals.",
  "publisher": "danielrkling",
  "repository": {
    "url": "https://github.com/danielkrling/tagged-jsx"
  },
  "version": "0.0.2",
  "engines": {
    "vscode": ">=1.70.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "jsx",
    "tagged templates"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/web/extension.js",
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "contributes": {
    "configuration": {
      "title": "JSX Tagged Templates",
      "properties": {
        "tagged-jsx.preferredTag": {
          "type": "string",
          "default": "jsx",
          "enum": ["jsx", "html"],
          "description": "Preferred tag name for JSX templates (jsx or html)"
        },
        "tagged-jsx.semanticTags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["jsx", "html"],
          "description": "Tag names to provide semantic highlighting for"
        },
        "tagged-jsx.customTags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["jsx", "html"],
          "description": "Custom tag names for TextMate grammar (syntax highlighting). Changing this requires reloading the extension."
        },
        "tagged-jsx.useCallbacks": {
          "type": "boolean",
          "default": false,
          "description": "Enable expression transform callbacks (wraps expressions with () => for tagged templates)"
        }
      }
    },
    "languages": [
      {
        "id": "jsx-tagged",
        "extensions": [
          ".jsxt"
        ],
        "aliases": [
          "JSX Tagged",
          "jsxt"
        ]
      }
    ],
    "grammars": [
      {
        "injectTo": [
          "source.js",
          "source.js.jsx",
          "source.jsx",
          "source.ts",
          "source.tsx",
          "text.html"
        ],
        "scopeName": "text.lit-jsx",
        "path": "./syntaxes/lit-jsx-generated.json",
        "embeddedLanguages": {
          "meta.embedded.block.jsx": "jsx-tagged"
        }
      },
      {
        "injectTo": [
          "source.js",
          "source.js.jsx",
          "source.jsx",
          "source.ts",
          "source.tsx",
          "text.html"
        ],
        "scopeName": "text.lit-jsx.string.injection",
        "path": "./syntaxes/lit-jsx-string-injection.json",
        "embeddedLanguages": {
          "meta.template.expression.ts": "typescript"
        }
      },
      {
        "language": "jsx-tagged",
        "scopeName": "text.jsx",
        "path": "./syntaxes/jsx.json"
      }
    ],
    "formatters": [
      {
        "id": "jsx Formatter",
        "languages": [
          "javascript",
          "typescript"
        ]
      }
    ],
    "typescriptServerPlugins": [
      {
        "name": "@tagged-jsx/ts-plugin"
      }
    ],
    "commands": [
      {
        "command": "tagged-jsx.regenerateGrammar",
        "title": "Tagged JSX: Regenerate Grammar"
      },
      {
        "command": "tagged-jsx.convertToJsx",
        "title": "Tagged JSX: Convert to jsx tag"
      },
      {
        "command": "tagged-jsx.convertToTagged",
        "title": "Tagged JSX: Convert to tagged template"
      },
      {
        "command": "tagged-jsx.toggle",
        "title": "Tagged JSX: Toggle (Smart Convert)"
      }
    ],
    "keybindings": [
      {
        "command": "tagged-jsx.toggle",
        "key": "ctrl+shift+j",
        "mac": "cmd+shift+j",
        "when": "editorTextFocus && (editorLangId == 'typescript' || editorLangId == 'typescriptreact' || editorLangId == 'javascript' || editorLangId == 'javascriptreact')"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.70.0",
    "@vscode/test-web": "^0.0.80",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.9",
    "@tagged-jsx/ts-plugin": "file:../ts-plugin",
    "@tagged-jsx/parse": "file:../parse",
    "@tagged-jsx/transform": "file:../transform",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "bundledDependencies": [
    "prettier",
    "@tagged-jsx/prettier-plugin",
    "prettier-plugin-embed"
  ],
  "scripts": {
    "build:web": "esbuild ./src/extension.web.ts --bundle --format=cjs --outfile=./dist/web/extension.js --external:vscode --minify",
    "build": "esbuild ./src/extension.ts --bundle --format=cjs --outfile=./dist/extension.js --external:vscode --bundle --platform=node",
    "watch": "esbuild ./src/extension.ts --bundle --format=cjs --outfile=./dist/extension.js --external:vscode --watch",
    "prepublish": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:web": "npx vscode-test-web --extensionDevelopmentPath=. --browserType=chromium"
  }
}
