{
  "name": "@tagged-jsx/transform",
  "version": "1.1.0",
  "description": "Transform between tagged template literals and JSX syntax",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --minify",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "jsx",
    "transform",
    "template-literal",
    "tagged-template"
  ],
  "author": "",
  "license": "MIT",
  "files": ["dist"],
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/diff": "^8.0.0",
    "@types/node": "^20.10.6",
    "solid-js": "^1.9.12",
    "tsdown": "^0.20.0-beta.3",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "dependencies": {
    "diff": "^9.0.0",
    "@tagged-jsx/parse": "^1.2.0",
    "typescript": "^5.3.3"
  }
}
